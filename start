#!/bin/bash

# bash (re)start script
# - stops any existing pm2 process for this server
# - assumes Redis is hosted separately (for example Upstash)
# - starts the API using pm2 with a configurable instance count
# - use your own server directory location if needed

[ ! -z "$(ps -ax | grep pm2 | grep -v grep)" ] && pm2 stop "server.js";

PM2_INSTANCES="${PM2_INSTANCES:-1}"
pm2 start "server.js" -i "${PM2_INSTANCES}" --wait-ready --listen-timeout 3000 --kill-timeout 6000 --update-env
